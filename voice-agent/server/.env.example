# voice-agent - Environment Variables
# Copy this file to .env and fill in your API keys


# Deepgram (STT — using flux-general-en via DeepgramFluxSTTService)
DEEPGRAM_API_KEY=

# Rumik SILK (TTS)
SILK_API_KEY=
SILK_BASE_URL=https://silk-api.rumik.ai
SILK_MODEL=muga                # "muga" (low-latency, tone-steered) or "mulberry" (expressive, description-steered)
SILK_TONE=neutral              # muga only: neutral | happy | sad | excited | angry | whisper
SILK_SPEAKER=                  # mulberry only: speaker_1..speaker_4
SILK_DESCRIPTION=              # mulberry only: natural-language voice description

# OpenRouter (LLM gateway — forced onto Cerebras for sub-100ms TTFT)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct   # Cerebras-hosted, non-reasoning, ~2200 tok/s. Alt: openai/gpt-oss-120b (reasoning, slower first audio)
OPENROUTER_PROVIDER=Cerebras           # comma-separated for fallback, e.g. "Cerebras,Groq,Fireworks"
